<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Night mode. -->
    <style name="Base.Theme.NontonCuyy" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">?attr/colorSurface</item>

        <!-- Custom attributes for theme switching -->
        <item name="colorSurface">@color/bg_dark</item>
        <item name="colorOnSurface">@color/text_night_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_night_secondary</item>
        <item name="colorSurfaceVariant">@color/surface_dark</item>
    </style>
</resources>